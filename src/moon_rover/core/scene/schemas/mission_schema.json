{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mission.yaml schema",
  "description": "Validates the top-level structure of mission.yaml for the Moon Rover simulation.",
  "type": "object",
  "required": ["rovers"],
  "additionalProperties": true,
  "properties": {
    "mission": {
      "type": "object",
      "properties": {
        "mission_id":   { "type": "string", "minLength": 1 },
        "name":         { "type": "string" },
        "description":  { "type": "string" }
      }
    },
    "grid": {
      "type": "object",
      "properties": {
        "spacing_m": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "rovers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rover_id", "rover_profile"],
        "properties": {
          "rover_id":      { "type": "string", "minLength": 1 },
          "rover_profile": { "type": "string", "minLength": 1 },
          "cable_id":      { "type": "string" },
          "grid_position": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "cable": {
      "type": "object",
      "properties": {
        "cable_id":            { "type": "string" },
        "length_m":            { "type": "number", "exclusiveMinimum": 0 },
        "diameter_mm":         { "type": "number", "exclusiveMinimum": 0 },
        "linear_density_kg_m": { "type": "number", "exclusiveMinimum": 0 },
        "max_tension_n":       { "type": "number", "exclusiveMinimum": 0 },
        "power": {
          "type": "object",
          "properties": {
            "enabled":             { "type": "boolean" },
            "voltage_dc":          { "type": "number", "exclusiveMinimum": 0 },
            "resistance_per_m_ohms":{ "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "waypoints": {},
    "success_criteria": {
      "type": "object"
    }
  }
}
