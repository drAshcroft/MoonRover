{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rover.yaml schema",
  "description": "Validates the top-level structure of rover.yaml for the Moon Rover simulation.",
  "type": "object",
  "required": ["profiles"],
  "additionalProperties": true,
  "properties": {
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["num_wheels", "mass_kg", "wheel_radius_m"],
        "properties": {
          "num_wheels":     { "type": "integer", "minimum": 2, "maximum": 6 },
          "mass_kg":        { "type": "number", "exclusiveMinimum": 0 },
          "wheel_radius_m": { "type": "number", "exclusiveMinimum": 0 },
          "track_width_m":  { "type": "number", "exclusiveMinimum": 0 },
          "wheelbase_m":    { "type": "number", "minimum": 0 },
          "skid_steer":     {},
          "inertia": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "com_offset": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "wheel_positions": { "type": "array" }
        }
      }
    },
    "arm": {
      "type": "object",
      "properties": {
        "num_dof":      { "type": "integer", "minimum": 1 },
        "reach_m":      { "type": "number", "exclusiveMinimum": 0 },
        "base_position":{ "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "gripper": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "power": {
      "type": "object",
      "properties": {
        "battery": {
          "type": "object",
          "properties": {
            "capacity_wh": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "structure": {
      "type": "object",
      "properties": {
        "chassis_material": { "type": "string", "minLength": 1 },
        "dimensions": {
          "type": "array",
          "items": { "type": "number", "exclusiveMinimum": 0 },
          "minItems": 3,
          "maxItems": 3
        }
      }
    }
  }
}
