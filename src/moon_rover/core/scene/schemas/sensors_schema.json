{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sensors.yaml schema",
  "description": "Validates the top-level structure of sensors.yaml for the Moon Rover sensor suite.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "sensor_suite": {
      "type": "object",
      "required": ["suite_id"],
      "properties": {
        "suite_id":     { "type": "string", "minLength": 1 },
        "name":         { "type": "string" },
        "description":  { "type": "string" },
        "total_power_w":{ "type": "number", "minimum": 0 }
      }
    },
    "lidar": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled":       { "type": "boolean" },
        "sensor_id":     { "type": "string" },
        "model":         { "type": "string" },
        "num_channels":  { "type": "integer", "minimum": 1 },
        "frequency_hz":  { "type": "number", "exclusiveMinimum": 0 },
        "mount_position":{ "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "fov": {
          "type": "object",
          "properties": {
            "horizontal_deg":    { "type": "number" },
            "vertical_lower_deg":{ "type": "number" },
            "vertical_upper_deg":{ "type": "number" }
          }
        },
        "range": {
          "type": "object",
          "properties": {
            "min_range_m": { "type": "number", "minimum": 0 },
            "max_range_m": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "imu": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled":        { "type": "boolean" },
        "sensor_id":      { "type": "string" },
        "frequency_hz":   { "type": "number", "exclusiveMinimum": 0 },
        "mount_position": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
      }
    },
    "force_torque_sensor": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled":      { "type": "boolean" },
        "sensor_id":    { "type": "string" },
        "frequency_hz": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "sun_sensor": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled":        { "type": "boolean" },
        "sensor_id":      { "type": "string" },
        "frequency_hz":   { "type": "number", "exclusiveMinimum": 0 },
        "mount_position": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
      }
    },
    "gps_beacon": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled":        { "type": "boolean" },
        "sensor_id":      { "type": "string" },
        "frequency_hz":   { "type": "number", "exclusiveMinimum": 0 },
        "mount_position": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
      }
    },
    "stereo_camera_front": {
      "type": "object",
      "properties": {
        "enabled":      { "type": "boolean" },
        "sensor_id":    { "type": "string" },
        "frequency_hz": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "navcam": {
      "type": "object",
      "properties": {
        "enabled":      { "type": "boolean" },
        "sensor_id":    { "type": "string" },
        "frequency_hz": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "sensor_fusion": {
      "type": "object",
      "properties": {
        "enabled":            { "type": "boolean" },
        "fusion_method":      { "type": "string" },
        "fusion_frequency_hz":{ "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "recording": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "format":  { "type": "string" }
      }
    }
  }
}
